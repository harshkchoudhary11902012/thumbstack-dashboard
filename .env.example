# ===========================================
# Copy and split for local development:
# - Server: copy to server/.env
# - Client: copy to client/.env.local
# ===========================================

# --- Server (server/.env) ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
JWT_SECRET=your-secret-key-min-32-chars
PORT=4000

# --- Client (client/.env.local) ---
# For local: use http://localhost:4000
# For production: use your deployed API URL (e.g. https://your-api.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:4000
